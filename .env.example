# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=inventory_db

# Session
SESSION_SECRET=change_me_long_random_string

# Frontend URL (the public URL users visit — used for OAuth callbacks and CORS)
FRONTEND_URL=https://your-domain.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Dropbox (file storage)
DROPBOX_ACCESS_TOKEN=

# Port the frontend nginx listens on (NPM proxies to this)
LISTEN_PORT=80

# Set to "true" on first deploy to seed demo data, then remove
# SEED_ON_STARTUP=true
